<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Task</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>
    <div class="container">
         <h1>Update Task</h1>
         <form class="todo-form" action="/update" method="post">
            <input type="hidden" name="id" value="<%= task._id %>">
            <input type="text" placeholder="Enter Task Title" name="title"  value="<%= task.title %>">
            <br/><br/>
            <textarea name="desc"><%= task.desc %></textarea>
            <br/><br/>
            <button>Update Task</button>
         </form>
    </div>
</body>
</html>