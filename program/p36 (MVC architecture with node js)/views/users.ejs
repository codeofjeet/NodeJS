<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User List</title>
    <style>
        h1{
            color: white;
            text-align: center;
            background-color: black;
            padding: 15px;
        }

        body{
            background-color: darkgreen;
            margin: 0;
            padding: 0;
        }

        .list{
            width: 25%;
            margin: 50px auto;
            background-color: antiquewhite;
            padding: 5px;
            list-style: none;
            font-size: 20px;
            text-align: center;
        }
    </style>
</head>
<body>
        <h1>User List Page</h1>
        <ul class="list">
            <% for(let i=0; i<users.length; i++) {%>
                <li><%= users[i] %></li>
            <%}%> 
        </ul>
</body>
</html>