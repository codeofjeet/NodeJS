<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student List</title>
</head>
<body>
    <table border="2" width="50%">
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Mark</th>
        </tr>
        <% result.forEach(student=>{ %>
            <tr>
            <td><%= student.name %></td>
            <td><%= student.age %></td>
            <td><%= student.mark %></td>
        </tr>
       <% }) %>
        
    </table>
</body>
</html>